{% layout 'theme' title: objects.product.title, description: objects.product.description, area: "product" %}
{% assign product = objects.product %}

<div class="product-page w-full flex flex-col items-center">

  <header class="product-hero w-full max-w-[1200px] px-8 pt-60 pb-20 text-center">
    <h1 class="hero-message" data-tilt-hero>
      <span class="hero-line-1">see what you can</span>
      <span class="hero-line-2">build</span>
    </h1>
  </header>

  {% comment %} Feature sections — each filled by an implementation task {% endcomment %}
  {% for section in product.sections %}
    {% assign n = forloop.index %}
    {% comment %} The closing CTA (last section) is rendered separately below. {% endcomment %}
    {% unless forloop.last %}
      <section class="product-section {% cycle 'frame-right', 'frame-left' %}" data-product-section data-section="{{ n }}">
        <div class="product-copy">
          <h2 class="section-title">{{ section.title }}</h2>
          <div class="section-content">{{ section.content }}</div>
        </div>
        <div class="product-frame-wrap" data-tilt>
          {% if n == 1 %}
            <div class="product-frame product-frame--shell">
              <div class="product-frame-glow" aria-hidden="true"></div>

              {% comment %} Top chrome bar {% endcomment %}
              <div class="pf-chrome" data-callout-target="1">
                <span class="pf-chrome-btn">Dashboard</span>
                <div class="pf-mode-toggle"><span class="on">Content</span><span>Task</span></div>
                <div class="pf-chrome-right">
                  <span class="pf-chrome-btn">Mobile</span>
                  <span class="pf-chrome-btn">View Live</span>
                  <span class="pf-chrome-btn">History</span>
                  <span class="pf-status"><i class="pf-dot ok"></i>Up to date</span>
                </div>
              </div>

              <div class="pf-body">
                {% comment %} Objects sidebar {% endcomment %}
                <div class="pf-sidebar" data-callout-target="4">
                  <div class="pf-sidebar-item active">Posts <b>12</b></div>
                  <div class="pf-sidebar-item">Pages <b>4</b></div>
                  <div class="pf-sidebar-item">Media <b>38</b></div>
                  <div class="pf-sidebar-item">Settings</div>
                </div>

                {% comment %} Glass editing panel {% endcomment %}
                <div class="pf-panel pf-glass" data-callout-target="2">
                  <div class="pf-field"><label>Title</label><div class="pf-input">Hello, world</div></div>
                  <div class="pf-field"><label>Published</label><div class="pf-input">Jul 6, 2026</div></div>
                  <div class="pf-field"><label>Draft</label><div class="pf-toggle"></div></div>
                </div>

                {% comment %} Live preview with mobile device frame {% endcomment %}
                <div class="pf-preview" data-callout-target="3">
                  <div class="pf-device">
                    <div class="pf-device-notch"></div>
                    <div class="pf-device-screen"></div>
                  </div>
                </div>
              </div>

              <button type="button" class="callout-marker" data-callout="1" style="--cx:20%; --cy:7%; --i:1;" aria-describedby="c1-1">1</button>
              <button type="button" class="callout-marker" data-callout="2" style="--cx:44%; --cy:52%; --i:2;" aria-describedby="c1-2">2</button>
              <button type="button" class="callout-marker" data-callout="3" style="--cx:80%; --cy:55%; --i:3;" aria-describedby="c1-3">3</button>
              <button type="button" class="callout-marker" data-callout="4" style="--cx:9%; --cy:45%; --i:4;" aria-describedby="c1-4">4</button>
            </div>

            <ol class="callout-legend">
              <li class="callout-item" data-callout="1" id="c1-1" style="--i:1;"><b>1</b> Switch between editing content and asking Archival to make changes for you.</li>
              <li class="callout-item" data-callout="2" id="c1-2" style="--i:2;"><b>2</b> A simple, focused panel to edit the page you're on — no code required.</li>
              <li class="callout-item" data-callout="3" id="c1-3" style="--i:3;"><b>3</b> Your real, live website — including a true-to-life mobile preview.</li>
              <li class="callout-item" data-callout="4" id="c1-4" style="--i:4;"><b>4</b> Every kind of content on your site, one tab away.</li>
            </ol>
          {% elsif n == 2 %}
            <div class="product-frame product-frame--prompt">
              <div class="product-frame-glow" aria-hidden="true"></div>

              {% comment %} Glowing AI prompt card {% endcomment %}
              <div class="pf-prompt-card pf-glass">
                <div class="pf-prompt-textarea" data-callout-target="1">Describe what type of site you'd like to create&hellip;</div>
                <div class="pf-prompt-row">
                  <div class="pf-attach-row" data-callout-target="2">
                    <span class="pf-chip"><i class="pf-chip-icon" aria-hidden="true"></i>Photos</span>
                    <span class="pf-chip"><i class="pf-chip-icon" aria-hidden="true"></i>Video</span>
                    <span class="pf-chip"><i class="pf-chip-icon" aria-hidden="true"></i>Audio</span>
                  </div>
                  <button class="pf-cta pf-generate-btn" type="button">Generate</button>
                </div>
              </div>

              {% comment %} 3-up generated template chooser {% endcomment %}
              <div class="pf-chooser" data-callout-target="3">
                <button class="pf-paddle pf-paddle-prev" type="button" aria-label="Previous site">&#8249;</button>

                <div class="pf-site-card">
                  <div class="pf-site-header"></div>
                  <div class="pf-site-block pf-site-block--wide"></div>
                  <div class="pf-site-block"></div>
                </div>

                <div class="pf-site-card pf-site-card--active">
                  <div class="pf-site-header"></div>
                  <div class="pf-site-block pf-site-block--wide"></div>
                  <div class="pf-site-block"></div>
                  <button class="pf-cta pf-golive-btn" type="button">Go Live</button>
                </div>

                <div class="pf-site-card">
                  <div class="pf-site-header"></div>
                  <div class="pf-site-block pf-site-block--wide"></div>
                  <div class="pf-site-block"></div>
                </div>

                <button class="pf-paddle pf-paddle-next" type="button" aria-label="Next site">&#8250;</button>
              </div>

              <button type="button" class="callout-marker" data-callout="1" style="--cx:50%; --cy:22%; --i:1;" aria-describedby="c2-1">1</button>
              <button type="button" class="callout-marker" data-callout="2" style="--cx:24%; --cy:40%; --i:2;" aria-describedby="c2-2">2</button>
              <button type="button" class="callout-marker" data-callout="3" style="--cx:50%; --cy:78%; --i:3;" aria-describedby="c2-3">3</button>
            </div>

            <ol class="callout-legend">
              <li class="callout-item" data-callout="1" id="c2-1" style="--i:1;"><b>1</b> Describe your site in plain language — no templates to pick through.</li>
              <li class="callout-item" data-callout="2" id="c2-2" style="--i:2;"><b>2</b> Attach photos, video, or audio you already have.</li>
              <li class="callout-item" data-callout="3" id="c2-3" style="--i:3;"><b>3</b> Archival generates three complete, real sites — pick your favorite and go live.</li>
            </ol>
          {% elsif n == 3 %}
            <div class="product-frame product-frame--content">
              <div class="product-frame-glow" aria-hidden="true"></div>

              {% comment %} Schema-driven object edit form {% endcomment %}
              <div class="pf-content-form pf-glass">
                <div class="pf-content-fields" data-callout-target="1">
                  <div class="pf-field">
                    <label>Title</label>
                    <div class="pf-input">Notes from the field</div>
                  </div>
                  <div class="pf-fields-row">
                    <div class="pf-field">
                      <label>Published</label>
                      <div class="pf-input">Jul 6, 2026</div>
                    </div>
                    <div class="pf-field">
                      <label>Featured</label>
                      <div class="pf-toggle"></div>
                    </div>
                  </div>
                  <div class="pf-field pf-field--unsynced">
                    <label><i class="pf-dot" aria-hidden="true"></i>Category</label>
                    <div class="pf-select">Essays<span class="pf-select-caret" aria-hidden="true">&#9662;</span></div>
                  </div>
                </div>

                {% comment %} Milkdown-style rich text area {% endcomment %}
                <div class="pf-markdown" data-callout-target="2">
                  <div class="pf-markdown-toolbar">
                    <span class="pf-md-btn"><b>B</b></span>
                    <span class="pf-md-btn"><i>I</i></span>
                    <span class="pf-md-btn">H</span>
                    <span class="pf-md-btn">&bull;</span>
                    <span class="pf-md-btn pf-md-btn--link" aria-hidden="true">&#128279;</span>
                  </div>
                  <div class="pf-markdown-body">
                    <p class="pf-md-line">Some mornings the light comes in <strong>sideways</strong>, and everything else can wait.</p>
                    <ul class="pf-md-list">
                      <li>Started before sunrise, finished long after.</li>
                    </ul>
                  </div>
                </div>

                {% comment %} Unsynced flag + revert/clear controls {% endcomment %}
                <div class="pf-unsynced-bar" data-callout-target="3">
                  <span class="pf-unsynced-flag"><i class="pf-dot" aria-hidden="true"></i>1 field unsynced</span>
                  <span class="pf-unsynced-actions">
                    <button class="pf-text-link pf-unsynced" type="button">Revert</button>
                    <button class="pf-text-link pf-unsynced" type="button">Clear</button>
                  </span>
                </div>
              </div>

              <button type="button" class="callout-marker" data-callout="1" style="--cx:28%; --cy:30%; --i:1;" aria-describedby="c3-1">1</button>
              <button type="button" class="callout-marker" data-callout="2" style="--cx:60%; --cy:60%; --i:2;" aria-describedby="c3-2">2</button>
              <button type="button" class="callout-marker" data-callout="3" style="--cx:30%; --cy:82%; --i:3;" aria-describedby="c3-3">3</button>
            </div>

            <ol class="callout-legend">
              <li class="callout-item" data-callout="1" id="c3-1" style="--i:1;"><b>1</b> Real, typed fields — text, dates, switches, dropdowns — not a pile of boxes.</li>
              <li class="callout-item" data-callout="2" id="c3-2" style="--i:2;"><b>2</b> Rich text that feels like a word processor, stored as clean content.</li>
              <li class="callout-item" data-callout="3" id="c3-3" style="--i:3;"><b>3</b> Unsaved edits are flagged, and any field reverts with one click.</li>
            </ol>
          {% elsif n == 4 %}
            <div class="product-frame product-frame--media">
              <div class="product-frame-glow" aria-hidden="true"></div>

              {% comment %} Image field editor: dropzone + upload progress + conversion/CDN badges {% endcomment %}
              <div class="pf-media-card pf-glass">
                <div class="pf-dropzone" data-callout-target="1">
                  <div class="pf-thumb" aria-hidden="true"></div>
                  <div class="pf-dropzone-text">
                    <span class="pf-dropzone-title">Drop image to upload</span>
                    <span class="pf-dropzone-sub">or click to browse</span>
                  </div>
                </div>

                <div class="pf-upload-progress" data-callout-target="2">
                  <div class="pf-progress-track">
                    <div class="pf-progress-fill" style="width: 67%;"></div>
                  </div>
                  <div class="pf-progress-label">Uploading&hellip; 67%</div>
                </div>

                <div class="pf-media-badges">
                  <span class="pf-badge">HEIC &rarr; PNG, auto</span>
                  <span class="pf-badge pf-badge--cdn" data-callout-target="3">Served from CDN &middot; deduplicated</span>
                </div>
              </div>

              <button type="button" class="callout-marker" data-callout="1" style="--cx:35%; --cy:34%; --i:1;" aria-describedby="c4-1">1</button>
              <button type="button" class="callout-marker" data-callout="2" style="--cx:55%; --cy:66%; --i:2;" aria-describedby="c4-2">2</button>
              <button type="button" class="callout-marker" data-callout="3" style="--cx:30%; --cy:84%; --i:3;" aria-describedby="c4-3">3</button>
            </div>

            <ol class="callout-legend">
              <li class="callout-item" data-callout="1" id="c4-1" style="--i:1;"><b>1</b> Drag in a photo — that's the whole workflow.</li>
              <li class="callout-item" data-callout="2" id="c4-2" style="--i:2;"><b>2</b> Phone formats like HEIC convert automatically as they upload.</li>
              <li class="callout-item" data-callout="3" id="c4-3" style="--i:3;"><b>3</b> Files go to a fast global network, and the same file is never stored twice.</li>
            </ol>
          {% elsif n == 5 %}
            <div class="product-frame product-frame--settings">
              <div class="product-frame-glow" aria-hidden="true"></div>

              {% comment %} Overview + DNS + recent deploys {% endcomment %}
              <div class="pf-settings-card pf-glass">
                <div class="pf-settings-overview">
                  <div class="pf-settings-row">
                    <span class="pf-settings-site"><i class="pf-dot ok" aria-hidden="true"></i>acme.com</span>
                    <span class="pf-settings-live">Live</span>
                  </div>
                  <div class="pf-settings-row">
                    <span class="pf-settings-label">Plan</span>
                    <span class="pf-settings-value">$14/mo</span>
                  </div>
                  <div class="pf-settings-row" data-callout-target="2">
                    <span class="pf-settings-label">GitHub</span>
                    <span class="pf-settings-value">acme-studio/acme-site</span>
                  </div>
                  <div class="pf-settings-row">
                    <span class="pf-settings-label">Billing</span>
                    <span class="pf-settings-value">&bull;&bull;&bull;&bull; 4242</span>
                  </div>
                </div>

                <div class="pf-dns" data-callout-target="1">
                  <div class="pf-dns-title">DNS records</div>
                  <div class="pf-dns-row">
                    <span class="pf-dns-type">A</span>
                    <span class="pf-dns-host">@</span>
                    <span class="pf-dns-value">76.76.21.21</span>
                  </div>
                  <div class="pf-dns-row">
                    <span class="pf-dns-type">CNAME</span>
                    <span class="pf-dns-host">www</span>
                    <span class="pf-dns-value">cname.archival.dev</span>
                  </div>
                  <div class="pf-dns-row">
                    <span class="pf-dns-type">TXT</span>
                    <span class="pf-dns-host">@</span>
                    <span class="pf-dns-value">v=spf1 include:_spf&hellip;</span>
                  </div>
                </div>

                <div class="pf-deploys" data-callout-target="3">
                  <div class="pf-deploys-title">Recent deploys</div>
                  <div class="pf-deploy-row">
                    <span class="pf-deploy-date">Jul 6</span>
                    <span class="pf-deploy-msg">Update homepage copy</span>
                    <i class="pf-dot ok" aria-hidden="true"></i>
                  </div>
                  <div class="pf-deploy-row">
                    <span class="pf-deploy-date">Jul 4</span>
                    <span class="pf-deploy-msg">Add new gallery images</span>
                    <i class="pf-dot ok" aria-hidden="true"></i>
                  </div>
                  <div class="pf-deploy-row">
                    <span class="pf-deploy-date">Jul 1</span>
                    <span class="pf-deploy-msg">Fix contact form styling</span>
                    <i class="pf-dot ok" aria-hidden="true"></i>
                  </div>
                </div>
              </div>

              <button type="button" class="callout-marker" data-callout="1" style="--cx:62%; --cy:30%; --i:1;" aria-describedby="c5-1">1</button>
              <button type="button" class="callout-marker" data-callout="2" style="--cx:26%; --cy:46%; --i:2;" aria-describedby="c5-2">2</button>
              <button type="button" class="callout-marker" data-callout="3" style="--cx:40%; --cy:78%; --i:3;" aria-describedby="c5-3">3</button>
            </div>

            <ol class="callout-legend">
              <li class="callout-item" data-callout="1" id="c5-1" style="--i:1;"><b>1</b> Buy a domain here or bring your own — Archival manages the DNS.</li>
              <li class="callout-item" data-callout="2" id="c5-2" style="--i:2;"><b>2</b> Every site is backed by a real repository you control.</li>
              <li class="callout-item" data-callout="3" id="c5-3" style="--i:3;"><b>3</b> A full, timestamped history of every deploy at a glance.</li>
            </ol>
          {% elsif n == 6 %}
            <div class="product-frame product-frame--history">
              <div class="product-frame-glow" aria-hidden="true"></div>

              {% comment %} Slide-in History panel: uncommitted changes + published commits {% endcomment %}
              <div class="pf-history-panel pf-glass">
                <div class="pf-history-header">
                  <span class="pf-history-title">History</span>
                </div>

                <div class="pf-history-group" data-callout-target="1">
                  <div class="pf-history-group-label">Upcoming changes</div>
                  <div class="pf-change-row">
                    <i class="pf-dot warn" aria-hidden="true"></i>
                    <span class="pf-change-desc">Edited: Home &rsaquo; Hero title</span>
                  </div>
                  <div class="pf-change-row">
                    <i class="pf-dot warn" aria-hidden="true"></i>
                    <span class="pf-change-desc">Added: Post &rsaquo; Summer sale</span>
                  </div>
                </div>

                <div class="pf-history-group">
                  <div class="pf-history-group-label">Published</div>
                  <div class="pf-commit-row">
                    <i class="pf-dot ok" aria-hidden="true"></i>
                    <span class="pf-commit-date">Jul 5</span>
                    <span class="pf-commit-msg">Publish spring collection</span>
                    <button class="pf-revert-btn" type="button">Revert</button>
                  </div>
                  <div class="pf-commit-row" data-callout-target="2">
                    <i class="pf-dot ok" aria-hidden="true"></i>
                    <span class="pf-commit-date">Jul 2</span>
                    <span class="pf-commit-msg">Rewrite about page</span>
                    <button class="pf-revert-btn" type="button">Revert</button>
                  </div>
                  <div class="pf-commit-row">
                    <i class="pf-dot ok" aria-hidden="true"></i>
                    <span class="pf-commit-date">Jun 28</span>
                    <span class="pf-commit-msg">Update team photos</span>
                    <button class="pf-revert-btn" type="button" data-callout-target="3">Revert</button>
                  </div>
                </div>
              </div>

              <button type="button" class="callout-marker" data-callout="1" style="--cx:50%; --cy:26%; --i:1;" aria-describedby="c6-1">1</button>
              <button type="button" class="callout-marker" data-callout="2" style="--cx:40%; --cy:58%; --i:2;" aria-describedby="c6-2">2</button>
              <button type="button" class="callout-marker" data-callout="3" style="--cx:78%; --cy:66%; --i:3;" aria-describedby="c6-3">3</button>
            </div>

            <ol class="callout-legend">
              <li class="callout-item" data-callout="1" id="c6-1" style="--i:1;"><b>1</b> See exactly what's changed before it goes live.</li>
              <li class="callout-item" data-callout="2" id="c6-2" style="--i:2;"><b>2</b> Every publish is a point in time you can return to.</li>
              <li class="callout-item" data-callout="3" id="c6-3" style="--i:3;"><b>3</b> Roll back any change &mdash; one edit or a whole day &mdash; instantly.</li>
            </ol>
          {% elsif n == 7 %}
            <div class="product-frame product-frame--publish">
              <div class="product-frame-glow" aria-hidden="true"></div>

              {% comment %} Dimmed editor top bar, peeking out behind the modal {% endcomment %}
              <div class="pf-publish-topbar">
                <span class="pf-publish-topbar-label">Editor</span>
                <span class="pf-status" data-callout-target="3"><i class="pf-dot warn" aria-hidden="true"></i>Publishing&hellip;</span>
              </div>

              {% comment %} Publish Changes modal, dimming the editor behind it {% endcomment %}
              <div class="pf-publish-backdrop">
                <div class="pf-publish-modal pf-glass">
                  <div class="pf-publish-header">
                    <span class="pf-publish-title">Publish Changes</span>
                  </div>

                  <div class="pf-publish-changes" data-callout-target="1">
                    <div class="pf-publish-change-row">
                      <span class="pf-publish-change-desc">Edited: About &rsaquo; Intro</span>
                      <button class="pf-publish-undo" type="button">Undo</button>
                    </div>
                    <div class="pf-publish-change-row">
                      <span class="pf-publish-change-desc">Added: Pricing &rsaquo; Tier</span>
                      <button class="pf-publish-undo" type="button">Undo</button>
                    </div>
                    <div class="pf-publish-change-row">
                      <span class="pf-publish-change-desc">Removed: Blog &rsaquo; Draft</span>
                      <button class="pf-publish-undo" type="button">Undo</button>
                    </div>
                  </div>

                  <div class="pf-publish-summary">
                    <label class="pf-publish-label">Commit summary</label>
                    <div class="pf-input pf-publish-textarea">Refresh hero and pricing</div>
                  </div>

                  <div class="pf-publish-actions">
                    <button class="pf-publish-cancel" type="button">Cancel</button>
                    <button class="pf-cta" type="button" data-callout-target="2">Publish</button>
                  </div>
                </div>
              </div>

              <button type="button" class="callout-marker" data-callout="1" style="--cx:42%; --cy:38%; --i:1;" aria-describedby="c7-1">1</button>
              <button type="button" class="callout-marker" data-callout="2" style="--cx:70%; --cy:74%; --i:2;" aria-describedby="c7-2">2</button>
              <button type="button" class="callout-marker" data-callout="3" style="--cx:24%; --cy:9%; --i:3;" aria-describedby="c7-3">3</button>
            </div>

            <ol class="callout-legend">
              <li class="callout-item" data-callout="1" id="c7-1" style="--i:1;"><b>1</b> Review everything that will change, and undo any of it.</li>
              <li class="callout-item" data-callout="2" id="c7-2" style="--i:2;"><b>2</b> One click and your site is live in seconds on Archival hosting.</li>
              <li class="callout-item" data-callout="3" id="c7-3" style="--i:3;"><b>3</b> Because it's a plain static site, you can also host the output anywhere yourself.</li>
            </ol>
          {% else %}
            {% comment %} FRAME {{ n }} — bespoke editor UI added by its task {% endcomment %}
          {% endif %}
        </div>
      </section>
    {% endunless %}
  {% endfor %}

  {% comment %} Closing CTA (reuses homepage prompt iframe pattern) {% endcomment %}
  {% assign cta = product.sections | last %}
  <section class="product-cta build-section">
    <h2 class="build-heading">{{ cta.title }}</h2>
    <div class="build-description">{{ cta.content }}</div>
    <iframe id="generate-frame"></iframe>
    <div class="primary-cta-container">
      <a href="https://editor.archival.dev/new" class="primary-cta" data-umami-event="product-cta-create">Create your site</a>
    </div>
  </section>

  <script>
  (function () {
    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Reveal sections on scroll
    var sections = document.querySelectorAll('[data-product-section]');
    if (reduce) {
      sections.forEach(function (s) { s.classList.add('is-visible'); });
    } else if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (e) {
          if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); }
        });
      }, { threshold: 0.25 });
      sections.forEach(function (s) { io.observe(s); });
    } else {
      sections.forEach(function (s) { s.classList.add('is-visible'); });
    }

    // Cross-highlight callouts: marker <-> line <-> legend <-> target
    sections.forEach(function (section) {
      function setActive(n, on) {
        section.querySelectorAll('[data-callout="' + n + '"], [data-callout-target="' + n + '"]')
          .forEach(function (el) { el.classList.toggle('callout-active', on); });
      }
      section.querySelectorAll('[data-callout]').forEach(function (trigger) {
        var n = trigger.getAttribute('data-callout');
        trigger.addEventListener('mouseenter', function () { setActive(n, true); });
        trigger.addEventListener('mouseleave', function () { setActive(n, false); });
        trigger.addEventListener('focus', function () { setActive(n, true); });
        trigger.addEventListener('blur', function () { setActive(n, false); });
      });
    });

    // 3D tilt on frames (adapted from the homepage tilt script)
    if (!reduce) {
      document.querySelectorAll('.product-frame-wrap[data-tilt]').forEach(function (card) {
        var frame = card.querySelector('.product-frame');
        if (!frame) return;
        var maxTilt = 6, bounds;
        card.addEventListener('mouseenter', function () { bounds = frame.getBoundingClientRect(); frame.style.transition = 'none'; });
        card.addEventListener('mousemove', function (e) {
          if (!bounds) return;
          var mx = e.clientX - bounds.left, my = e.clientY - bounds.top;
          var rx = ((my - bounds.height / 2) / (bounds.height / 2)) * -maxTilt;
          var ry = ((mx - bounds.width / 2) / (bounds.width / 2)) * maxTilt;
          frame.style.transform = 'perspective(1200px) rotateX(' + rx + 'deg) rotateY(' + ry + 'deg)';
        });
        card.addEventListener('mouseleave', function () {
          frame.style.transition = 'transform 0.4s ease-out';
          frame.style.transform = 'perspective(1200px) rotateX(0) rotateY(0)';
        });
      });

      // Mouse-follow tilt on the hero (matches the homepage hero-tilt behavior)
      document.querySelectorAll('[data-tilt-hero]').forEach(function (hero) {
        var heroMaxTilt = 12, heroPerspective = 1200;
        document.addEventListener('mousemove', function (e) {
          var rx = ((e.clientY - window.innerHeight / 2) / (window.innerHeight / 2)) * -heroMaxTilt;
          var ry = ((e.clientX - window.innerWidth / 2) / (window.innerWidth / 2)) * heroMaxTilt;
          hero.style.setProperty('--hero-mouse-x', (e.clientX / window.innerWidth) * 100 + '%');
          hero.style.setProperty('--hero-mouse-y', (e.clientY / window.innerHeight) * 100 + '%');
          hero.style.transform = 'perspective(' + heroPerspective + 'px) rotateX(' + rx + 'deg) rotateY(' + ry + 'deg)';
        });
        document.addEventListener('mouseleave', function () {
          hero.style.transition = 'transform 0.5s ease-out';
          hero.style.transform = 'perspective(1200px) rotateX(0deg) rotateY(0deg)';
        });
      });
    }
  })();
  </script>

</div>
