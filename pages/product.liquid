{% layout 'theme' title: objects.product.title
  , description: objects.product.description
  , area: "product" %}
{% assign product = objects.product %}

  <div class="product-page w-full flex flex-col items-center">

  <header class="product-hero w-full max-w-[1200px] px-8 pt-60 pb-20 text-center">
    <h1 class="hero-message" data-tilt-hero>
      <span class="hero-line-1">see what you can</span>
      <span class="hero-line-2">build</span>
    </h1>
  </header>

  {% comment %} Feature sections, each filled by an implementation task {% endcomment %}
  {% for section in product.sections %}
    {% assign n = forloop.index %}
    {% comment %} The closing CTA (last section) is rendered separately below. {% endcomment %}
    {% unless forloop.last %}
      <section
        class="product-section {% cycle 'frame-right', 'frame-left' %}"
        data-product-section
        data-section="{{ n }}">
        <div class="product-copy">
          <h2 class="section-title">{{ section.title }}</h2>
          <div class="section-content">{{ section.content }}</div>
        </div>
        <div class="product-frame-wrap" data-tilt>
          {% if section.key == "editor" %}
            <div class="product-frame product-frame--shell">
              <div class="product-frame-glow" aria-hidden="true"></div>

              {% comment %} Top chrome bar {% endcomment %}
              <div class="pf-chrome" data-callout-target="1">
                <span class="pf-chrome-btn">History</span>
                <div class="pf-mode-toggle">
                  <span class="on">Content</span>
                  <span>Task</span>
                </div>
                <div class="pf-chrome-right">
                  <span class="pf-chrome-btn" data-callout-target="4">Mobile</span>
                  <span class="pf-chrome-btn">View Live</span>
                  <span class="pf-status">
                    <i class="pf-dot ok"></i>
                  </span>
                </div>
              </div>

              <div class="pf-body">
                {% comment %} Site sections sidebar {% endcomment %}
                <div class="pf-sidebar">
                  <div class="pf-sidebar-item active">Site</div>
                  <div class="pf-sidebar-item">Gallery</div>
                  <div class="pf-sidebar-item">About</div>
                  <div class="pf-sidebar-item">Contact</div>
                </div>

                {% comment %} Glass editing panel {% endcomment %}
                <div class="pf-panel pf-glass" data-callout-target="2">
                  <div class="pf-field">
                    <label>Title</label>
                    <div class="pf-input">Hello, world</div>
                  </div>
                  <div class="pf-field">
                    <label>Published</label>
                    <div class="pf-input">Jul 6, 2026</div>
                  </div>
                  <div class="pf-field">
                    <label>Draft</label>
                    <div class="pf-toggle"></div>
                  </div>
                </div>

                {% comment %} Live preview: desktop website wireframe {% endcomment %}
                <div class="pf-preview" data-callout-target="3">
                  <div class="pf-browser">
                    <div class="pf-browser-bar">
                      <span class="pf-browser-dot"></span>
                      <span class="pf-browser-dot"></span>
                      <span class="pf-browser-dot"></span>
                      <div class="pf-browser-url"></div>
                    </div>
                    <div class="pf-browser-page">
                      <div class="pf-wire-nav">
                        <div class="pf-wire-logo"></div>
                        <div class="pf-wire-navlinks">
                          <span></span>
                          <span></span>
                          <span></span>
                        </div>
                      </div>
                      <div class="pf-wire-hero">
                        <div class="pf-wire-hero-copy">
                          <div class="pf-wire-line pf-wire-line--title"></div>
                          <div class="pf-wire-line"></div>
                          <div class="pf-wire-line pf-wire-line--short"></div>
                          <div class="pf-wire-btn"></div>
                        </div>
                        <div class="pf-wire-hero-art"></div>
                      </div>
                      <div class="pf-wire-cards">
                        <div class="pf-wire-card"></div>
                        <div class="pf-wire-card"></div>
                        <div class="pf-wire-card"></div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <button
                type="button"
                class="callout-marker"
                data-callout="1"
                style="--cx:52%; --cy:9.2%; --i:1;"
                aria-describedby="c1-1">1</button>
              <button
                type="button"
                class="callout-marker"
                data-callout="2"
                style="--cx:28.1%; --cy:61.7%; --i:2;"
                aria-describedby="c1-2">2</button>
              <button
                type="button"
                class="callout-marker"
                data-callout="3"
                style="--cx:80.4%; --cy:58.1%; --i:3;"
                aria-describedby="c1-3">3</button>
              <button
                type="button"
                class="callout-marker"
                data-callout="4"
                style="--cx:72.5%; --cy:15.5%; --i:4;"
                aria-describedby="c1-4">4</button>
            </div>

            <ol class="callout-legend">
