                  </div>
                  <div class="pf-deploy-row">
                    <span class="pf-deploy-date">Jul 4</span>
                    <span class="pf-deploy-msg">Add new gallery images</span>
                    <i class="pf-dot ok" aria-hidden="true"></i>
                  </div>
                  <div class="pf-deploy-row">
                    <span class="pf-deploy-date">Jul 1</span>
                    <span class="pf-deploy-msg">Fix contact form styling</span>
