                      <i class="pf-chip-icon" aria-hidden="true"></i>Photos</span>
                    <span class="pf-chip">
                      <i class="pf-chip-icon" aria-hidden="true"></i>Video</span>
                    <span class="pf-chip">
                      <i class="pf-chip-icon" aria-hidden="true"></i>Audio</span>
