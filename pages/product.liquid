              <button
                type="button"
                class="callout-marker"
                data-callout="1"
                style="--cx:94.7%; --cy:35.2%; --i:1;"
                aria-describedby="c6-1">1</button>
              <button
                type="button"
                class="callout-marker"
                data-callout="2"
                style="--cx:94.7%; --cy:72.6%; --i:2;"
                aria-describedby="c6-2">2</button>
              <button
                type="button"
                class="callout-marker"
                data-callout="3"
                style="--cx:76.7%; --cy:84%; --i:3;"
                aria-describedby="c6-3">3</button>
            </div>

            <ol class="callout-legend">
              <li
                class="callout-item"
                data-callout="1"
                id="c6-1"
                style="--i:1;">
